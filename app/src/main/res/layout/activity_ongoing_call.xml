<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <SurfaceView
        android:id="@+id/video_remote"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <SurfaceView
        android:id="@+id/video_local"
        android:layout_width="100dp"
        android:layout_height="130dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_margin="12dp"
        android:background="#33FFFFFF" />

    <LinearLayout
        android:id="@+id/layout_top"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        android:background="#88000000"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/tv_caller_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Kapı Zili"
            android:textColor="#FFFFFF"
            android:textSize="22sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tv_duration"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="00:00"
            android:textColor="#BBBBBB"
            android:textSize="16sp" />
    </LinearLayout>

    <TextView
        android:id="@+id/tv_door_status"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="🔓 Kapı Açıldı!"
        android:textColor="#4CAF50"
        android:textSize="24sp"
        android:textStyle="bold"
        android:background="#CC000000"
        android:padding="16dp"
        android:visibility="gone"
        android:alpha="0"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <LinearLayout
        android:id="@+id/layout_bottom"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        android:background="#CC000000"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/tv_dtmf_input"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="#64B5F6"
            android:textSize="18sp"
            android:gravity="center"
            android:minHeight="28dp"
            android:layout_marginBottom="8dp" />

        <Button
            android:id="@+id/btn_open_door"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:text="🔓  KAPIYI AÇ"
            android:textSize="20sp"
            android:textStyle="bold"
            android:backgroundTint="#E65100"
            android:textColor="#FFFFFF"
            android:layout_marginBottom="12dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">

            <Button
                android:id="@+id/btn_mute"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="🎤 Sessiz"
                android:backgroundTint="#444444"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:layout_marginEnd="6dp" />

            <Button
                android:id="@+id/btn_speaker"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="📱 Kulak"
                android:backgroundTint="#444444"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:alpha="0.5"
                android:layout_marginEnd="6dp" />

            <Button
                android:id="@+id/btn_hang_up"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="📵 Kapat"
                android:backgroundTint="#C62828"
                android:textColor="#FFFFFF"
                android:textSize="13sp" />
        </LinearLayout>

        <GridLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:columnCount="3"
            android:rowCount="4">

            <Button android:id="@+id/btn1" android:text="1" style="@style/DtmfButton" />
            <Button android:id="@+id/btn2" android:text="2" style="@style/DtmfButton" />
            <Button android:id="@+id/btn3" android:text="3" style="@style/DtmfButton" />
            <Button android:id="@+id/btn4" android:text="4" style="@style/DtmfButton" />
            <Button android:id="@+id/btn5" android:text="5" style="@style/DtmfButton" />
            <Button android:id="@+id/btn6" android:text="6" style="@style/DtmfButton" />
            <Button android:id="@+id/btn7" android:text="7" style="@style/DtmfButton" />
            <Button android:id="@+id/btn8" android:text="8" style="@style/DtmfButton" />
            <Button android:id="@+id/btn9" android:text="9" style="@style/DtmfButton" />
            <Button android:id="@+id/btn_star" android:text="*" style="@style/DtmfButton" />
            <Button android:id="@+id/btn0" android:text="0" style="@style/DtmfButton" />
            <Button android:id="@+id/btn_hash" android:text="#" style="@style/DtmfButton" />
        </GridLayout>

        <TextView
            android:id="@+id/tv_dtmf_code"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Kapı Kodu: #"
            android:textColor="#888888"
            android:textSize="12sp"
            android:gravity="center"
            android:layout_marginTop="4dp" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
